# Vite only exposes VITE_-prefixed vars to the browser bundle.
# Copy to .env.local (gitignored) and fill in.

# Public Sentry DSN used by the browser SDK. Safe to commit if you prefer.
VITE_SENTRY_DSN=https://your-public-key@o0.ingest.sentry.io/0

# Sourcemap upload credentials (used only during `pnpm build` / `pnpm run deploy`).
# Create an internal integration token with project:releases + project:read scopes:
# https://docs.sentry.io/product/accounts/auth-tokens/
SENTRY_AUTH_TOKEN=
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug
